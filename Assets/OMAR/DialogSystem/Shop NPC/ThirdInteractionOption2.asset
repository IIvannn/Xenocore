--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a49675d3da19b054686ae9ecd58461ad, type: 3}
  m_Name: ThirdInteractionOption2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speakerName: Rift
    text: Because this planet is full of questions and nobody bothers to look for
      answers.
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: dfd49278aaeff4b4a9423e9a4dedf194, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: d01bd1b437def094c9a6780dbdad5281, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Rift
    text: I collect energy, yeah. But I also collect stories. Clues. Pieces of whatever
      lived here before us.
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: 19b79383905171c41b80cd4bec17b504, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: c0c12ae43e657414daba01b6fa3e183f, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Rift
    text: Different races walked this place. Built things. Fought things. Maybe even
      tried to save it.
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: c048e118567af15419bcdcc777d7bf53, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: 7dd5bd74fab0f024d8b7d28ff2d45b8c, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Rift
    text: "If I gather enough fragments, maybe I\u2019ll understand what they were
      trying to do. Maybe I\u2019ll understand what went wrong."
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: c048e118567af15419bcdcc777d7bf53, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: 582011cdf7050c44f8084097286d9f66, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Rift
    text: "Anyway. That\u2019s it. Don\u2019t make it weird."
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: 19b79383905171c41b80cd4bec17b504, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: 582011cdf7050c44f8084097286d9f66, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Rift
    text: "Now move, rookie. The forest isn\u2019t going to wait for you."
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: dfd49278aaeff4b4a9423e9a4dedf194, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: 582011cdf7050c44f8084097286d9f66, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  options: []
  isFinalDialogue: 1
