%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a49675d3da19b054686ae9ecd58461ad, type: 3}
  m_Name: option4 Lumena First
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speakerName: Lumena
    text: "The signal you\u2019re following\u2026 it isn\u2019t here on the surface.
      It\u2019s coming from deep inside Astraeon."
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: 9d1852908ff850847b5159c766e754fd, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: c0c12ae43e657414daba01b6fa3e183f, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Lumena
    text: "The core\u2019s instability pushes energy upward. It twists the wildlife,
      makes them aggressive. When they fall, that energy breaks apart."
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: 05ab1f653215476409a566237c2bb668, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: c0c12ae43e657414daba01b6fa3e183f, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Lumena
    text: "Your device can absorb those fragments. Xenocore Elements. You\u2019ll
      need them."
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: 05ab1f653215476409a566237c2bb668, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: c0c12ae43e657414daba01b6fa3e183f, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Kaelaris
    text: "So defeating the creatures isn\u2019t optional."
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: 9d1852908ff850847b5159c766e754fd, type: 3}
    isLeftSpeaker: 1
    leftPortrait: {fileID: 21300000, guid: ae6777ac6a52f3340b37a7632bbd4eb9, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Lumena
    text: No. Their fragments will help you move forward.
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: 05ab1f653215476409a566237c2bb668, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: c0c12ae43e657414daba01b6fa3e183f, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Lumena
    text: "The Elyndari built a temple in these woods. It was used to channel the
      Xenocore Elements into the planet. It\u2019s still there\u2026 dormant."
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: b88736a349bfb8e44997cca803c3da53, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: c0c12ae43e657414daba01b6fa3e183f, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Lumena
    text: "If you want to reach the signal, you\u2019ll have to activate it. The
      temple responds to Xenocore energy. Gather enough fragments, defeat the guardian
      and it will open the way inside the planet."
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: 05ab1f653215476409a566237c2bb668, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: c0c12ae43e657414daba01b6fa3e183f, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Kaelaris
    text: And I do that alone?
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: 9d1852908ff850847b5159c766e754fd, type: 3}
    isLeftSpeaker: 1
    leftPortrait: {fileID: 21300000, guid: ae6777ac6a52f3340b37a7632bbd4eb9, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Lumena
    text: There is someone who can help you. An Astraelite named Rift.
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: 05ab1f653215476409a566237c2bb668, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: ae6777ac6a52f3340b37a7632bbd4eb9, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Lumena
    text: "He knows how to find Xenocore Elements. How to stabilize them. He\u2019s
      rough around the edges, but he understands this place better than most."
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: b88736a349bfb8e44997cca803c3da53, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: c0c12ae43e657414daba01b6fa3e183f, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Lumena
    text: "Find Rift. He\u2019ll help you gather what you need\u2026 and guide you
      to the temple."
    voiceClip: {fileID: 0}
    typingSpeed: 0.03
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: 05ab1f653215476409a566237c2bb668, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: c0c12ae43e657414daba01b6fa3e183f, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  options: []
  isFinalDialogue: 1
