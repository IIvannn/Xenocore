  m_Script: {fileID: 11500000, guid: a49675d3da19b054686ae9ecd58461ad, type: 3}
  m_Name: LumenaThirdInteractionOption1
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speakerName: Lumena
    text: "We weren\u2019t warriors or conquerors. We were caretakers."
    voiceClip: {fileID: 8300000, guid: d8d477aff7c9940478e89f860b1c0fde, type: 3}
    typingSpeed: 0
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: b88736a349bfb8e44997cca803c3da53, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: c0c12ae43e657414daba01b6fa3e183f, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Lumena
    text: We shaped the resonance so the world could grow. We healed what broke.
      We listened to what the planet needed.
    voiceClip: {fileID: 8300000, guid: d8d477aff7c9940478e89f860b1c0fde, type: 3}
    typingSpeed: 0
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: 05ab1f653215476409a566237c2bb668, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: 40eddda1543e24346865a91cacd547f2, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Lumena
    text: "But when the presence beneath Astraeon began to awake\u2026 we couldn\u2019t
      heal it. It wasn\u2019t a wound. It was something else."
    voiceClip: {fileID: 8300000, guid: d8d477aff7c9940478e89f860b1c0fde, type: 3}
    typingSpeed: 0
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: 05ab1f653215476409a566237c2bb668, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: 7dd5bd74fab0f024d8b7d28ff2d45b8c, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Lumena
    text: "That\u2019s why the Ritual was created."
    voiceClip: {fileID: 8300000, guid: d8d477aff7c9940478e89f860b1c0fde, type: 3}
    typingSpeed: 0
    showOptionsHere: 0
    jumpBackToPreviousDialogue: 0
    previousDialogueLineIndex: 0
    speakerSprite: {fileID: 21300000, guid: 9d1852908ff850847b5159c766e754fd, type: 3}
    isLeftSpeaker: 0
    leftPortrait: {fileID: 21300000, guid: 7dd5bd74fab0f024d8b7d28ff2d45b8c, type: 3}
    customFont: {fileID: 11400000, guid: 84c1d05c69deacd4cb1362b81cba58e6, type: 2}
  - speakerName: Lumena
    text: Back to options
    voiceClip: {fileID: 8300000, guid: d8d477aff7c9940478e89f860b1c0fde, type: 3}
    typingSpeed: 0
    showOptionsHere: 0
